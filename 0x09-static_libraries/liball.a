#include "main.h"

/**
 * _strncpy - Copies a string
 * @dest: character pointer
 * @src: character pointer
 * @n: integer variable
 *
 * Return: return character
 */
char *_strncpy(char *dest, char *src, int n)
{
	int i;

	for (i = 0; i < n && src[i] != '\0'; i++)
	{
		dest[i] = src[i];
	}

	for (; i < n; i++)
	{
		dest[i] = '\0';
	}

	return (dest);
}
